# PAM configuration file for Nix-built hyprlock on Ubuntu/generic Linux.
#
# Keep this local-password-only. Nix-built linux-pam loads modules from the
# Nix store, so Ubuntu's common-auth/common-account may reference modules that
# are unavailable there, such as pam_sss.so or pam_cap.so.

auth required pam_unix.so
account required pam_unix.so
