layout { 
    focus-ring {
        off
        width 0.5
        active-color "#e0def4"
    }

    border {
        on
        width 0.5
        active-color "#908caa"
        inactive-color "#56526e"
    }

    shadow {
        on
        softness 10
        spread 1
        offset x=0 y=0
        color "#c4a7e7c0"
        inactive-color "#2a283e70"
    }

    background-color "44415a"
}

window-rule {
    match is-focused=false
    opacity 0.98
}
