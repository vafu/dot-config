layout {
    focus-ring {
        on
        width 1
        active-color "#5c6066"
    }
    shadow {
        on
        softness 8
        spread 0
        offset x=0 y=0
        color "#717c7c"
        inactive-color "#22262d"
    }
    background-color  "#1f1f26"
}

window-rule {
    geometry-corner-radius 8
    clip-to-geometry true
}

cursor {
    xcursor-theme "BreezeX-RosePine-Linux"
    xcursor-size 24
}
