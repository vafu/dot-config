#!/usr/bin/env bash
set -euo pipefail

working_dir="/tmp"

mountpoint="${LOCUS_ROOT:-${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/locusfs}"
project_path_file="$mountpoint/context/selected/workspace/project/path"

if [[ -r "$project_path_file" ]]; then
  IFS= read -r project_dir < "$project_path_file" || project_dir=""
  if [[ -n "${project_dir:-}" && -d "$project_dir" ]]; then
    working_dir="$project_dir"
  fi
fi

exec ghostty \
  --window-inherit-working-directory=false \
  --working-directory="$working_dir" \
  +new-window
