#!/bin/sh
set -u

if [ "$#" -lt 4 ]; then
  echo "Usage: locus-wrap-app <name> <icon> -- <command> [args...]" >&2
  exit 2
fi

app_name=$1
app_icon=$2
shift 2
if [ "${1:-}" = "--" ]; then
  shift
fi

if [ "$#" -eq 0 ]; then
  echo "Usage: locus-wrap-app <name> <icon> -- <command> [args...]" >&2
  exit 2
fi

safe_part() {
  printf '%s' "$1" | tr -c '[:alnum:]_' '_'
}

selected_window=$(locusctl context get selected window --first 2>/dev/null || true)
app_part=$(safe_part "$app_name")
app_node="app-instance:${app_part}/$$-$(date +%s%N)"
linked=0

cleanup() {
  if [ "$linked" = 1 ]; then
    locusctl link remove "$selected_window" app-instance "$app_node" >/dev/null 2>&1 || true
  fi
}

trap cleanup EXIT HUP INT TERM

if [ -n "$app_part" ] && [ "${selected_window#window:}" != "$selected_window" ]; then
  locusctl prop set "$app_node" kind app-instance >/dev/null 2>&1 \
    && locusctl prop set "$app_node" name "$app_name" >/dev/null 2>&1 \
    && locusctl prop set "$app_node" icon "$app_icon" >/dev/null 2>&1 \
    && locusctl link set "$selected_window" app-instance "$app_node" >/dev/null 2>&1 \
    && linked=1
fi

"$@"
status=$?
exit "$status"
