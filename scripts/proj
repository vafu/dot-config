#!/usr/bin/env bash
set -euo pipefail

LOCUS_SH="${LOCUS_SH:-$HOME/.config/locus/locus.sh}"

usage() {
  cat >&2 <<'EOF'
Usage:
  proj init [--force] [path]
  proj publish [path]
  proj root [path]
  proj metadata <key> [path]
EOF
}

die() {
  echo "proj: $*" >&2
  exit 1
}

absolute_dir() {
  local path="${1:-$PWD}"
  cd "$path" 2>/dev/null && pwd -P
}

project_root_for_path() {
  local path="${1:-$PWD}"
  local dir
  dir="$(absolute_dir "$path")" || return 1

  while [[ "$dir" != "/" ]]; do
    if [[ -f "$(metadata_file "$dir")" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="${dir%/*}"
    [[ -n "$dir" ]] || dir="/"
  done

  return 1
}

metadata_file() {
  printf '%s/.project.json\n' "$1"
}

json_get() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || return 1
  jq -er --arg key "$key" '.[$key] // empty' "$file"
}

json_locus_properties() {
  local file="$1"
  [[ -f "$file" ]] || return 1
  jq -r '
    to_entries[]
    | select(.value != null)
    | [.key, (if (.value | type) == "string" then .value else (.value | tojson) end)]
    | @tsv
  ' "$file"
}

project_name() {
  local root="$1"
  local file
  file="$(metadata_file "$root")"
  json_get "$file" name || basename "$root"
}

icon_picker() {
  printf '%s\n' "${LOCUS_ICON_PICKER:-pick-icon}"
}

first_icon_from_picker_output() {
  awk '
    /^[[:space:]]*\[/ {
      if (match($0, /"icon"[[:space:]]*:[[:space:]]*"[^"]+"/)) {
        value = substr($0, RSTART, RLENGTH)
        sub(/^"icon"[[:space:]]*:[[:space:]]*"/, "", value)
        sub(/"$/, "", value)
        print value
        exit
      }
    }
    NF { print $1; exit }
  '
}

pick_icon() {
  local query="$1"
  local root="${2:-}" picker output
  picker="$(icon_picker)"
  command -v "$picker" >/dev/null 2>&1 || return 0
  if [[ -n "$root" ]]; then
    output="$("$picker" -n 1 -s "$query" -f "$root/AGENTS.md" -f "$root/README.md" || true)"
  else
    output="$("$picker" -n 1 -s "$query" || true)"
  fi
  printf '%s\n' "$output" | first_icon_from_picker_output
}

git_branch_name() {
  local root="$1"
  git -C "$root" branch --show-current 2>/dev/null || true
}

git_worktree_path() {
  local root="$1"
  git -C "$root" rev-parse --show-toplevel 2>/dev/null || true
}

worktree_name() {
  local path="$1"
  [[ -n "$path" ]] || return 0
  basename "$path"
}

selected_workspace() {
  local workspace
  if [[ -r "$LOCUS_SH" ]]; then
    # shellcheck disable=SC1090
    . "$LOCUS_SH"
    workspace="$(locus_selected_workspace 2>/dev/null || true)"
    if [[ "$workspace" == workspace:* ]]; then
      printf '%s\n' "$workspace"
      return 0
    fi
  fi
  workspace="$(locusctl resolve context:selected workspace 2>/dev/null || true)"
  if [[ "$workspace" == workspace:* ]]; then
    printf '%s\n' "$workspace"
    return 0
  fi
  locusctl prop subjects --key focused --value true 2>/dev/null \
    | awk '/^workspace:/ { print; exit }'
}

cmd_init() {
  local force=0 path="${1:-}"
  if [[ "${1:-}" == "--force" ]]; then
    force=1
    shift
    path="${1:-}"
  fi

  local root file name icon
  root="$(absolute_dir "${path:-$PWD}")" || die "directory not found: ${path:-$PWD}"
  file="$(metadata_file "$root")"
  if [[ -e "$file" && "$force" != 1 ]]; then
    die "$file already exists; use --force to overwrite"
  fi

  name="$(basename "$root")"
  icon=""
  icon="$(pick_icon "$name")"

  jq -n --arg name "$name" --arg icon "$icon" \
    '{name: $name, icon: (if $icon == "" then null else $icon end)}' \
    > "$file"
  printf '%s\n' "$file"
}

cmd_publish() {
  local root workspace subject file name key value branch worktree_path worktree saw_notebook_scope
  local -a mutations
  root="$(project_root_for_path "${1:-$PWD}")" || return 0
  workspace="$(selected_workspace || true)"
  [[ "$workspace" == workspace:* ]] || return 0

  subject="project:$root"
  file="$(metadata_file "$root")"
  name="$(project_name "$root")"
  branch="$(git_branch_name "$root")"
  worktree_path="$(git_worktree_path "$root")"
  worktree="$(worktree_name "$worktree_path")"

  mutations=()
  saw_notebook_scope=0
  mutations+=("set-property"$'\t'"$subject"$'\t'"kind"$'\t'"project")
  mutations+=("set-property"$'\t'"$subject"$'\t'"path"$'\t'"$root")
  mutations+=("set-property"$'\t'"$subject"$'\t'"name"$'\t'"$name")
  if [[ -n "$worktree_path" ]]; then
    mutations+=("set-property"$'\t'"$subject"$'\t'"worktree"$'\t'"$worktree")
    mutations+=("set-property"$'\t'"$subject"$'\t'"worktree-path"$'\t'"$worktree_path")
  else
    mutations+=("remove-property"$'\t'"$subject"$'\t'"worktree"$'\t')
    mutations+=("remove-property"$'\t'"$subject"$'\t'"worktree-path"$'\t')
  fi
  if [[ -n "$branch" ]]; then
    mutations+=("set-property"$'\t'"$subject"$'\t'"branch"$'\t'"$branch")
  else
    mutations+=("remove-property"$'\t'"$subject"$'\t'"branch"$'\t')
  fi
  while IFS=$'\t' read -r key value; do
    [[ -n "$key" ]] || continue
    case "$key" in
      kind|path|name|branch|worktree|worktree-path)
        continue
        ;;
      notebook_scope)
        saw_notebook_scope=1
        ;;
    esac
    mutations+=("set-property"$'\t'"$subject"$'\t'"$key"$'\t'"$value")
  done < <(json_locus_properties "$file")
  if [[ "$saw_notebook_scope" == 0 ]]; then
    mutations+=("remove-property"$'\t'"$subject"$'\t'"notebook_scope"$'\t')
  fi
  mutations+=("set-link"$'\t'"$workspace"$'\t'"project"$'\t'"$subject")
  printf '%s\n' "${mutations[@]}" | locusctl apply >/dev/null
}

cmd_root() {
  project_root_for_path "${1:-$PWD}" || return 1
}

cmd_metadata() {
  local key="${1:-}"
  [[ -n "$key" ]] || die "metadata key is required"
  shift || true
  local root file
  root="$(project_root_for_path "${1:-$PWD}")" || return 1
  file="$(metadata_file "$root")"
  json_get "$file" "$key"
}

case "${1:-}" in
  init)
    shift
    cmd_init "$@"
    ;;
  publish)
    shift
    cmd_publish "$@"
    ;;
  root)
    shift
    cmd_root "$@"
    ;;
  metadata)
    shift
    cmd_metadata "$@"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac
